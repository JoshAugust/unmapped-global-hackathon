{
  "_schema_version": "1.0",
  "_description": "Country configuration schema for UNMAPPED. All country-specific parameters live here. Swap this file to reconfigure the entire system for a new context without changing codebase.",
  "_co_owned_with": "Owner B (UX/product layer reads this for UI config)",

  "country": {
    "name": "Ghana",
    "iso3": "GHA",
    "iso2": "GH",
    "region": "Sub-Saharan Africa",
    "subregion": "West Africa",
    "economy_type": "urban_informal_mixed",
    "primary_language": "en",
    "supported_languages": ["en", "tw"],
    "currency": "GHS",
    "currency_symbol": "₵",
    "usd_exchange_rate_approx": 12.5,
    "usd_exchange_rate_year": 2023
  },

  "data_paths": {
    "labour_market": "data/gha/wdi_labour.json",
    "occupation_lookup": "data/isco_fo_joined.csv",
    "automation_calibration": "config/calibration.json"
  },

  "automation": {
    "calibration_factor": 0.65,
    "calibration_rationale": "Ghana urban informal. ILO (2016) SSA automation ~77% of OECD rate, further reduced 15% for informal task composition difference. See calibration_notes.md",
    "source_dataset": "Frey-Osborne 2013, ISCO-08 crosswalk",
    "recalibration_trigger": "Update when ILO publishes updated task-content indices for Ghana (next expected 2025)"
  },

  "education_taxonomy": {
    "levels": [
      {"code": "L0", "label": "No formal education", "isco_skill_level": 1},
      {"code": "L1", "label": "Primary (JHS incomplete)", "isco_skill_level": 1},
      {"code": "L2", "label": "Junior High School (BECE)", "isco_skill_level": 1},
      {"code": "L3", "label": "Senior High School (WASSCE)", "isco_skill_level": 2},
      {"code": "L4", "label": "TVET / Apprenticeship certificate", "isco_skill_level": 2},
      {"code": "L5", "label": "HND / Polytechnic diploma", "isco_skill_level": 3},
      {"code": "L6", "label": "University degree", "isco_skill_level": 4},
      {"code": "L7", "label": "Postgraduate", "isco_skill_level": 4}
    ],
    "informal_recognition": {
      "enabled": true,
      "categories": ["apprenticeship", "self_taught", "community_training", "on_job_experience"],
      "note": "Ghana's informal apprenticeship system (Ghanaian system of traditional apprenticeship / GSTA) is recognized as a valid credential pathway"
    }
  },

  "opportunity_types": {
    "formal_employment": {"enabled": true, "label": "Formal job"},
    "self_employment": {"enabled": true, "label": "Run your own business"},
    "gig_platform": {"enabled": true, "label": "Platform work (Bolt, Glovo, etc.)"},
    "training_pathway": {"enabled": true, "label": "Training or upskilling"},
    "apprenticeship": {"enabled": true, "label": "Apprenticeship"},
    "cooperative": {"enabled": true, "label": "Join a cooperative or group business"}
  },

  "econometric_signals": {
    "signal_1": {
      "name": "Sector wage comparison",
      "description": "Monthly earnings by economic sector (formal sector only)",
      "data_field": "wages.mean_monthly_earnings_usd",
      "vintage": "ILO ILOSTAT 2017 (most recent available for Ghana)",
      "display_unit": "USD/month",
      "display_caveat": "Formal sector only. Informal sector wages typically 30-60% lower."
    },
    "signal_2": {
      "name": "Sector growth outlook",
      "description": "Which sectors are growing or declining in your economy",
      "data_field": "sector_growth_outlook",
      "vintage": "World Bank Ghana Economic Update 2023",
      "display_unit": "Qualitative (High / Medium / Declining)",
      "display_caveat": "Forward-looking estimate. Actual growth depends on policy and global conditions."
    }
  },

  "ui": {
    "default_language": "en",
    "font_stack": "system-ui, sans-serif",
    "locale": "en-GH",
    "number_format": "1,234.56",
    "date_format": "DD/MM/YYYY",
    "low_bandwidth_mode": true,
    "image_loading": "lazy",
    "max_initial_payload_kb": 150,
    "primary_color": "#1B5E8A",
    "accent_color": "#F7A800",
    "onboarding_tone": "warm_direct",
    "reading_level_target": "secondary_school"
  },

  "skill_input_questions": [
    {
      "id": "q_work_activity",
      "question_en": "What do you spend most of your working time doing?",
      "type": "select_with_freetext",
      "options_en": [
        "Selling goods (market, shop, online)",
        "Repairing phones, electronics, or appliances",
        "Sewing, tailoring, or making clothes",
        "Driving or transport",
        "Cooking, food prep, or catering",
        "Construction or building work",
        "Farming or growing food",
        "Teaching or training others",
        "Office or admin work",
        "Healthcare or caring for others",
        "IT or computer work",
        "Something else"
      ],
      "maps_to": "isco08_primary"
    },
    {
      "id": "q_education",
      "question_en": "What is your highest level of education?",
      "type": "select",
      "options_en": ["No formal education", "Primary school", "Junior High School (BECE)", "Senior High School (WASSCE)", "TVET or apprenticeship certificate", "HND or diploma", "University degree", "Postgraduate"],
      "maps_to": "education_level_code"
    },
    {
      "id": "q_informal_skills",
      "question_en": "Have you taught yourself any skills outside of school? (select all that apply)",
      "type": "multi_select",
      "options_en": ["Basic computer use", "Using smartphones and apps", "Social media for business", "Accounting or bookkeeping", "A trade through apprenticeship", "A language", "Nothing specific"],
      "maps_to": "informal_skills_tags"
    },
    {
      "id": "q_years_experience",
      "question_en": "How many years have you been doing your main work activity?",
      "type": "select",
      "options_en": ["Less than 1 year", "1-2 years", "3-5 years", "More than 5 years"],
      "maps_to": "experience_years_band"
    },
    {
      "id": "q_goal",
      "question_en": "What are you most hoping to do?",
      "type": "select",
      "options_en": ["Find a formal job", "Grow my own business", "Learn a new skill", "Understand what jobs pay", "See how AI might affect my work"],
      "maps_to": "user_goal"
    }
  ]
}
