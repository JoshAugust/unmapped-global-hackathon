  "automation": {
    "calibration_factor": 0.58,
    "calibration_rationale": "Bangladesh has the world's second-largest garment sector with high routine manual task concentration, making automation potential significant. However, massive informal economy (85%+), low capital intensity, and cheap labour slow actual adoption. Factor reflects high theoretical exposure dampened by structural barriers.",
    "source_dataset": "Frey-Osborne 2013, ISCO-08 crosswalk",
    "recalibration_trigger": "Update when BBS Labour Force Survey 2025 publishes occupation-level task data"
  },
  "education_taxonomy": {
    "levels": [
      { "code": "L0", "label": "No formal education", "isco_skill_level": 1 },
      { "code": "L1", "label": "Primary (Class 1-5)", "isco_skill_level": 1 },
      { "code": "L2", "label": "Junior Secondary (Class 6-8)", "isco_skill_level": 1 },
      { "code": "L3", "label": "Secondary School Certificate (SSC)", "isco_skill_level": 2 },
      { "code": "L4", "label": "Higher Secondary Certificate (HSC)", "isco_skill_level": 2 },
      { "code": "L5", "label": "Diploma / Technical certificate", "isco_skill_level": 2 },
      { "code": "L6", "label": "Bachelor's degree", "isco_skill_level": 3 },
      { "code": "L7", "label": "Master's degree", "isco_skill_level": 4 },
      { "code": "L8", "label": "Postgraduate / MPhil / PhD", "isco_skill_level": 4 }
    ],
    "informal_recognition": {
      "enabled": true,
      "categories": [
        "apprenticeship",
        "self_taught",
        "ngo_training",
        "madrasa_education",
        "on_job_experience"
      ],
      "note": "Bangladesh has extensive NGO-led skills training (BRAC, Grameen) and a parallel madrasa education system. Informal apprenticeship in garment and construction sectors is widespread."
    }
  },
  "opportunity_types": {
    "formal_employment": { "enabled": true, "label": "Formal job" },
    "self_employment": { "enabled": true, "label": "Start or grow a business" },
    "gig_platform": { "enabled": true, "label": "Platform work (Pathao, Uber, freelance)" },
    "training_pathway": { "enabled": true, "label": "Training or upskilling" },
    "garment_sector": { "enabled": true, "label": "Ready-Made Garment (RMG) sector" },
    "remittance_services": { "enabled": true, "label": "Mobile financial services / bKash agent" },
    "cooperative": { "enabled": true, "label": "Cooperative or NGO-supported enterprise" }
  },
  "econometric_signals": {
    "signal_1": {
      "name": "Sector wage comparison",
      "description": "Monthly earnings by economic sector",
      "data_field": "wages.mean_monthly_earnings_usd",
      "vintage": "BBS Labour Force Survey 2022",
      "display_unit": "USD/month",
      "display_caveat": "Formal sector only. RMG sector minimum wage ~$113/month after 2023 revision."
    },
    "signal_2": {
      "name": "Sector growth outlook",
      "description": "Which sectors are growing or declining",
      "data_field": "sector_growth_outlook",
      "vintage": "World Bank Bangladesh Development Update 2024",
      "display_unit": "Qualitative",
      "display_caveat": "Garment export diversification and IT/BPO growth are key trends."
    }
  },
  "ui": {
    "default_language": "bn",
    "font_stack": "system-ui, sans-serif",
    "locale": "bn-BD",
    "number_format": "1,234.56",
    "date_format": "DD/MM/YYYY",
    "low_bandwidth_mode": true,
