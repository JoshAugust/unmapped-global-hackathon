{
  "_schema_version": "1.0",
  "_description": "Bangladesh configuration. Swap this for any other country_config to reconfigure UNMAPPED for Bangladesh. No codebase changes required.",
  "country": {
    "name": "Bangladesh",
    "iso3": "BGD",
    "iso2": "BD",
    "region": "South Asia",
