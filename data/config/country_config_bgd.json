    "accent_color": "#f42a41",
    "onboarding_tone": "warm_respectful",
    "reading_level_target": "ssc_level"
  },
  "skill_input_questions": [
    {
      "id": "q_work_activity",
      "question_en": "What do you spend most of your working time doing?",
